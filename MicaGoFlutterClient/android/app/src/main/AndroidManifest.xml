<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- MicaGo talks to the relay server over HTTP(S). INTERNET must be in the
         main manifest (Flutter only auto-adds it to debug/profile builds). -->
    <uses-permission android:name="android.permission.INTERNET"/>
    <!-- Camera is used only for the QR pairing scanner (mobile_scanner). -->
    <uses-permission android:name="android.permission.CAMERA"/>
    <uses-feature android:name="android.hardware.camera" android:required="false"/>
    <!-- Read-only contacts, requested on demand for local handle→name matching.
         WRITE_CONTACTS is intentionally NOT declared; contacts are never
         modified or uploaded. -->
    <uses-permission android:name="android.permission.READ_CONTACTS"/>
    <!-- C21c: photo_manager reads the gallery for the attachment media grid.
         Android 13+ uses the granular READ_MEDIA_* permissions; older versions
         fall back to READ_EXTERNAL_STORAGE (capped at SDK 32). Media is only
         read to stage attachments the user selects; nothing is uploaded without
         an explicit send. -->
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES"/>
    <uses-permission android:name="android.permission.READ_MEDIA_VIDEO"/>
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32"/>
    <!-- C22: show FCM-driven message notifications on Android 13+. -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS"/>
    <!-- C29: optional "Keep MicaGo running" foreground service that holds the
         WebSocket open in the background. Off by default; only started when the
         user enables it in advanced settings. dataSync = keep a sync connection. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE"/>
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC"/>
    <application
        android:label="MicaGo"
        android:name="${applicationName}"
        android:icon="@mipmap/ic_launcher"
        android:usesCleartextTraffic="true">
        <!-- usesCleartextTraffic enables plain http:// to local/LAN servers
             (e.g. http://192.168.x.x). Public endpoints use https via the tunnel. -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:taskAffinity=""
            android:theme="@style/LaunchTheme"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode"
            android:hardwareAccelerated="true"
            android:windowSoftInputMode="adjustResize">
            <!-- Specifies an Android theme to apply to this Activity as soon as
                 the Android process has started. This theme is visible to the user
                 while the Flutter UI initializes. After that, this theme continues
                 to determine the Window background behind the Flutter UI. -->
            <meta-data
              android:name="io.flutter.embedding.android.NormalTheme"
              android:resource="@style/NormalTheme"
              />
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>
        <!-- C29: optional keep-alive foreground service (off by default). -->
        <service
            android:name=".KeepAliveService"
            android:exported="false"
            android:foregroundServiceType="dataSync" />
        <!-- Don't delete the meta-data below.
             This is used by the Flutter tool to generate GeneratedPluginRegistrant.java -->
        <meta-data
            android:name="flutterEmbedding"
            android:value="2" />
    </application>
    <!-- Required to query activities that can process text, see:
         https://developer.android.com/training/package-visibility and
         https://developer.android.com/reference/android/content/Intent#ACTION_PROCESS_TEXT.

         In particular, this is used by the Flutter engine in io.flutter.plugin.text.ProcessTextPlugin. -->
    <queries>
        <intent>
            <action android:name="android.intent.action.PROCESS_TEXT"/>
            <data android:mimeType="text/plain"/>
        </intent>
    </queries>
</manifest>
